{
  "name": "ditsmod-starter",
  "type": "module",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "start": "npm run build && node --enable-source-maps dist/main.js",
    "node-watch": "node --watch --enable-source-maps dist/main.js",
    "start:dev": "run-p 'build -- --watch' node-watch",
    "build-test": "tsc -b tsconfig.e2e.json --watch",
    "test": "tsc -b tsconfig.e2e.json && npm run esm-jest",
    "esm-jest": "node --experimental-vm-modules --no-warnings=ExperimentalWarning --enable-source-maps node_modules/jest/bin/jest.js",
    "lint": "eslint .",
    "clean": "rimraf dist*"
  },
  "imports": {
    "#app/*": "./dist/app/*"
  },
  "keywords": [],
  "author": "Your Name Here",
  "license": "MIT",
  "engines": {
    "node": ">= 20.6.0"
  },
  "dependencies": {
    "@ditsmod/body-parser": "^3.0.0-alpha.6",
    "@ditsmod/core": "^3.0.0-alpha.6",
    "@ditsmod/rest": "^3.0.0-alpha.6"
  },
  "devDependencies": {
    "@ditsmod/testing": "^3.0.0-alpha.6",
    "@eslint/js": "^9.39.4",
    "@types/eslint__js": "^8.42.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.39",
    "@types/supertest": "^6.0.3",
    "eslint": "^8.57.1",
    "jest": "^30.3.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.3",
    "rimraf": "^5.0.10",
    "supertest": "^6.3.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.1"
  }
}
